<?php

use Livewire\Component;
use Livewire\WithPagination;
use App\Enums\OrderStatus;
use App\Enums\PaymentMethod;
use App\Enums\TransactionType;
use App\Models\Order;
use App\Models\Transaction;
use Illuminate\Validation\Rule;

new #[Title('Encaissements - Commandes non soldées')] class extends Component {
    use WithPagination;

    public $search = '';
    public $perPage = 15;

    public $showPaymentModal = false;
    public $payingOrderId = null;
    public $paymentAmount = 0;
    public $paymentMethod = '';
    public $paymentExternalRef = '';
    public $paymentNotes = '';

    public $showCancelModal = false;
    public $cancellingTransaction = null;
    public $cancellationReason = '';

    public $showEditModal = false;
    public $editingTransaction = null;
    public $editAmount = 0;
    public $editMethod = '';
    public $editExternalRef = '';
    public $editNotes = '';

    public $showTransactionsModal = false;
    public $viewingOrderId = null;

    public function updatedSearch() { $this->resetPage(); }
    public function updatedPerPage() { $this->resetPage(); }

    public function clearFilters()
    {
        $this->reset('search');
        $this->resetPage();
    }

    public function openPaymentModal(int $orderId): void
    {
        $order = Order::findOrFail($orderId);
        $this->payingOrderId = $orderId;
        $this->paymentAmount = max(0, floatval($order->remaining_balance));
        $this->paymentMethod = '';
        $this->paymentExternalRef = '';
        $this->paymentNotes = '';
        $this->showPaymentModal = true;
    }

    public function processPayment(): void
    {
        $this->validate([
            'paymentAmount' => 'required|numeric|min:1',
            'paymentMethod' => ['required', Rule::enum(PaymentMethod::class)],
            'paymentExternalRef' => 'nullable|string|max:255',
            'paymentNotes' => 'nullable|string|max:1000',
        ]);

        $order = Order::findOrFail($this->payingOrderId);

        $order->transactions()->create([
            'type' => TransactionType::PAYMENT->value,
            'amount' => $this->paymentAmount,
            'payment_method' => $this->paymentMethod,
            'external_ref' => $this->paymentExternalRef ?: null,
            'notes' => $this->paymentNotes ?: null,
            'paid_at' => now(),
            'reference' => Transaction::generateReference('PAY'),
            'user_id' => auth()->id(),
        ]);

        $this->dispatch('toast', variant: 'success', heading: 'Paiement enregistré.');
        $this->showPaymentModal = false;
        $this->payingOrderId = null;
    }

    public function openCancelModal(int $transactionId): void
    {
        $this->cancellingTransaction = Transaction::with('order', 'user')->findOrFail($transactionId);
        $this->cancellationReason = '';
        $this->showCancelModal = true;
    }

    public function processCancel(): void
    {
        $this->validate([
            'cancellationReason' => 'required|string|min:3|max:1000',
        ]);

        $this->cancellingTransaction->cancel($this->cancellationReason);

        $this->dispatch('toast', variant: 'success', heading: 'Paiement annulé.');
        $this->showCancelModal = false;
        $this->cancellingTransaction = null;
    }

    public function openEditModal(int $transactionId): void
    {
        $this->editingTransaction = Transaction::with('order', 'user')->findOrFail($transactionId);
        $this->editAmount = floatval($this->editingTransaction->amount);
        $this->editMethod = $this->editingTransaction->payment_method?->value ?? '';
        $this->editExternalRef = $this->editingTransaction->external_ref ?? '';
        $this->editNotes = $this->editingTransaction->notes ?? '';
        $this->showEditModal = true;
    }

    public function processEdit(): void
    {
        $this->validate([
            'editAmount' => 'required|numeric|min:1',
            'editMethod' => ['required', Rule::enum(PaymentMethod::class)],
            'editExternalRef' => 'nullable|string|max:255',
            'editNotes' => 'nullable|string|max:1000',
        ]);

        $this->editingTransaction->edit([
            'amount' => $this->editAmount,
            'payment_method' => $this->editMethod,
            'external_ref' => $this->editExternalRef ?: null,
            'notes' => $this->editNotes ?: null,
        ]);

        $this->dispatch('toast', variant: 'success', heading: 'Paiement modifié.');
        $this->showEditModal = false;
        $this->editingTransaction = null;
    }

    public function openTransactionsModal(int $orderId): void
    {
        $this->viewingOrderId = $orderId;
        $this->showTransactionsModal = true;
    }

    public function closeTransactionsModal(): void
    {
        $this->viewingOrderId = null;
        $this->showTransactionsModal = false;
    }

    public function with(): array
    {
        $query = Order::with(['transactions' => fn($q) => $q->notCancelled()->latest('paid_at')])
            ->notCancelled()
            ->unsettled()
            ->latest('created_at');

        if (!empty($this->search)) {
            $query->where(function ($q) {
                $q->where('reference', 'like', '%' . $this->search . '%')
                  ->orWhere('client_name', 'like', '%' . $this->search . '%')
                  ->orWhere('client_phone', 'like', '%' . $this->search . '%');
            });
        }

        return [
            'orders' => $query->paginate($this->perPage),
            'isFiltered' => !empty($this->search),
            'paymentMethods' => PaymentMethod::cases(),
            'totalPayments' => Transaction::where('type', 'payment')
                ->notCancelled()
                ->whereHas('order', fn($q) => $q->unsettled())
                ->sum('amount'),
            'unsettledOrders' => Order::notCancelled()->unsettled()->count(),
            'totalOutstanding' => Order::notCancelled()
                ->selectRaw('SUM(total_amount - ' . Order::netPaidSubquery() . ') as outstanding', [TransactionType::PAYMENT->value, TransactionType::REFUND->value])
                ->unsettled()
                ->value('outstanding'),
            'viewingOrderTransactions' => $this->viewingOrderId
                ? Order::with(['transactions' => fn($q) => $q->notCancelled()->latest('paid_at')])
                    ->find($this->viewingOrderId)
                : null,
        ];
    }
}; ?>

